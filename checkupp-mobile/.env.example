# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
EXPO_PUBLIC_FIREBASE_DATABASE_URL=your_firebase_database_url

# CheckUpp API
# iOS simulator: http://localhost:3090/api/v1
# Android emulator: http://10.0.2.2:3090/api/v1
# Physical device: http://<your-lan-ip>:3090/api/v1
# If omitted, the app will try to infer your Expo dev host IP automatically.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3090/api/v1
# Set to true when checkupp-api is running with AUTH_MODE=dev
EXPO_PUBLIC_API_DEV_MODE=true

# Appwrite Configuration
EXPO_PUBLIC_APPWRITE_ENDPOINT=your_appwrite_endpoint
EXPO_PUBLIC_APPWRITE_PLATFORM=your_app_package_name
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_appwrite_project_id
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_appwrite_database_id
EXPO_PUBLIC_APPWRITE_STORAGE_ID=your_appwrite_storage_id
EXPO_PUBLIC_APPWRITE_USER_COLLECTION_ID=your_user_collection_id
EXPO_PUBLIC_APPWRITE_FILE_COLLECTION_ID=your_file_collection_id
EXPO_PUBLIC_APPWRITE_FEEDBACK_COLLECTION_ID=your_feedback_collection_id
EXPO_PUBLIC_APPWRITE_NUTRITION_COLLECTION_ID=your_nutrition_collection_id
EXPO_PUBLIC_APPWRITE_PEDIATRIC_COLLECTION_ID=your_pediatric_collection_id
EXPO_PUBLIC_APPWRITE_PREG_PLANNER_COLLECTION_ID=your_preg_planner_collection_id
EXPO_PUBLIC_APPWRITE_PRE_EMPLOYMENT_COLLECTION_ID=your_pre_employment_collection_id
EXPO_PUBLIC_APPWRITE_CANCER_SCREENING_COLLECTION_ID=your_cancer_screening_collection_id

# Google OAuth Client IDs
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
